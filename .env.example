# ==============================================================================
# CONFIGURACIÓN GLOBAL DE INFRAESTRUCTURA (DOCKER COMPOSE)
# ==============================================================================
# Puertos expuestos en tu máquina local (host)
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Ramas o referencias de Git para la construcción de imágenes
REPO_REF_BACKEND=docker
REPO_REF_FRONTEND=docker


# ==============================================================================
# BASE DE DATOS (POSTGRESQL + POSTGIS)
# ==============================================================================
# Configuración que lee Postgres únicamente en su primer arranque
POSTGRES_VERSION=15.3
POSTGRES_DB=LeadchainDB
POSTGRES_USER=root
POSTGRES_PASSWORD=root

# Puerto de conexión para el contenedor de la Base de Datos
DB_PORT=5432


# ==============================================================================
# BACKEND (LARAVEL CORE)
# ==============================================================================
# Entorno y depuración del Backend
APP_ENV=production
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

# Credenciales de conexión de Laravel a la base de datos (Deben coincidir con Postgres)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_DATABASE=LeadchainDB
DB_USERNAME=root
DB_PASSWORD=root

# --- Selección de Datos Iniciales (Seeders) ---
# Opción A: Cargar base de datos completa con datos de prueba (Desarrollo/Presentación)
SEEDER_CLASS=DatabaseSeeder

# Opción B: Cargar solo cuentas iniciales de administración (Producción)
# SEEDER_CLASS=ProduccionSeeder


# ==============================================================================
# FRONTEND (VITE / REACT)
# ==============================================================================
# URL base de la API. Dejar vacío para usar rutas relativas y evitar problemas de CORS
VITE_API_BASE_URL=


# ==============================================================================
# EXPOSICIÓN PÚBLICA (NGROK)
# ==============================================================================
# Token de acceso obtenido de dashboard.ngrok.com
NGROK_AUTHTOKEN=