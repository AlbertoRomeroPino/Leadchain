# Docker Compose environment for local Leadchain development
# Cambia estas credenciales cuando quieras.
APP_ENV=production
APP_URL=http://127.0.0.1:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=LeadchainDB
DB_USERNAME=root
DB_PASSWORD=root

POSTGRES_VERSION=15.3
POSTGRES_DB=LeadchainDB
POSTGRES_USER=root
POSTGRES_PASSWORD=root
BACKEND_PORT=8000
FRONTEND_PORT=5173

# En el frontend, el navegador consumirá el backend por la IP local del PC.
# Cámbiala al host de tu ordenador en la red Wi-Fi.
VITE_API_BASE_URL=http://192.168.1.40:8000
